# Docker environment configuration
# Загружается Docker Compose автоматически

POSTGRES_USER=quizcraft_user
POSTGRES_PASSWORD=quizcraft_pass
POSTGRES_DB=quizcraft_db

DJANGO_SETTINGS_MODULE=backend.settings
DATABASE_URL=postgresql://quizcraft_user:quizcraft_pass@db:5432/quizcraft_db
PYTHONUNBUFFERED=1

VITE_API_URL=http://localhost:8000
